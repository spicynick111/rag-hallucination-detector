# Groq API (100% FREE — get key at https://console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# PostgreSQL Database (optional — app works without it)
DATABASE_URL=postgresql://postgres:password@localhost:5432/llm_eval_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=llm_eval_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# App Settings
APP_ENV=development
LOG_LEVEL=INFO
